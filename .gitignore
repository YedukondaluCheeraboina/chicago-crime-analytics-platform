# ==========================================================
# Chicago Crime Analytics Platform
# Git Ignore
# ==========================================================

# ==========================================================
# Python
# ==========================================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================================
# Virtual Environments
# ==========================================================
venv/
.venv/
env/
ENV/

# ==========================================================
# Environment Variables
# ==========================================================
.env
.env.*
!.env.example

# ==========================================================
# Streamlit
# ==========================================================
.streamlit/secrets.toml

# ==========================================================
# IDE Settings
# ==========================================================
.vscode/
.idea/
*.code-workspace

# ==========================================================
# Operating System Files
# ==========================================================
.DS_Store
Thumbs.db
Desktop.ini

# ==========================================================
# Logs
# ==========================================================
*.log
logs/

# ==========================================================
# Database Files
# ==========================================================
*.db
*.sqlite
*.sqlite3

# ==========================================================
# Build / Distribution
# ==========================================================
build/
dist/
*.egg-info/
.eggs/

# ==========================================================
# Testing
# ==========================================================
.pytest_cache/
.coverage
htmlcov/

# ==========================================================
# Jupyter
# ==========================================================
.ipynb_checkpoints/

# ==========================================================
# Temporary Files
# ==========================================================
*.tmp
*.temp
*.bak
*.swp

# ==========================================================
# Generated Reports (Optional)
# Uncomment if you don't want generated files in Git
# ==========================================================
# reports/generated/
# graphs/
# exports/

# ==========================================================
# MySQL Dumps (Optional)
# ==========================================================
*.sql.bak